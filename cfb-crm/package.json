{
  "name": "cfb-crm",
  "private": true,
  "workspaces": [
    "apps/global-api",
    "apps/app-api",
    "apps/web",
    "apps/mobile",
    "packages/*"
  ],
  "scripts": {
    "mobile":     "npm run start --workspace=apps/mobile",
    "global-api": "npm run dev --workspace=apps/global-api",
    "app-api":    "npm run dev --workspace=apps/app-api",
    "dev":        "concurrently \"npm run global-api\" \"npm run app-api\"",
    "typecheck":  "npm run typecheck --workspaces --if-present",
    "lint":       "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "typescript": "^5.3.3"
  }
}
