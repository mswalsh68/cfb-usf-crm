# ─── Global API ──────────────────────────────────────────────
# Copy to apps/global-api/.env
#thisis a test

NODE_ENV=development
PORT=3001

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_64_BYTE_HEX_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX_STRING

# Azure SQL — Global DB
GLOBAL_DB_SERVER=your-server.database.windows.net
GLOBAL_DB_NAME=LegacyLinkGlobal
# For local dev only (prod uses managed identity):
GLOBAL_DB_USER=your-db-user
GLOBAL_DB_PASS=your-db-password

# CORS — comma-separated origins
ALLOWED_ORIGINS=http://localhost:8081,exp://localhost:8081

---

# ─── App API ──────────────────────────────────────────────────
# Copy to apps/app-api/.env
# Handles both roster and alumni data for a tenant's AppDB

NODE_ENV=development
PORT=3002

JWT_ACCESS_SECRET=SAME_SECRET_AS_GLOBAL_API

# Azure SQL — tenant DB routing is per-request from JWT (appDb + dbServer)
# These are used for the /health check only:
DB_SERVER=your-server.database.windows.net
DB_USER=your-db-user
DB_PASS=your-db-password
DB_ENCRYPT=true
DB_TRUST_CERT=false

ALLOWED_ORIGINS=http://localhost:8081,exp://localhost:8081

---

# ─── Mobile App ───────────────────────────────────────────────
# Copy to apps/mobile/.env

# All EXPO_PUBLIC_ vars are bundled into the app — never put secrets here
EXPO_PUBLIC_GLOBAL_API_URL=http://localhost:3001
EXPO_PUBLIC_APP_API_URL=http://localhost:3002

# For device/simulator testing — use your machine's local IP:
# EXPO_PUBLIC_GLOBAL_API_URL=http://192.168.1.x:3001
